<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.ASCSR" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.ASCSR" parent="Base.Theme.ASCSR" />
    <style name="DarkAlertDialogTheme" parent="Theme.MaterialComponents.Dialog.Alert">
        <item name="android:background">#112240</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="colorAccent">#3D8EFF</item>
        <item name="buttonBarPositiveButtonStyle">@style/AlertPositiveBtn</item>
        <item name="buttonBarNegativeButtonStyle">@style/AlertNegativeBtn</item>
    </style>
    <style name="AlertPositiveBtn" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">#3D8EFF</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AlertNegativeBtn" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">#FF6B6B</item>
    </style>
</resources>
