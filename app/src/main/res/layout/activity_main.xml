<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1B2D"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="40dp"
        android:paddingBottom="40dp">

        <!-- Header Card with Logo -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="#1A2D45"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="32dp"
                android:paddingBottom="28dp"
                android:paddingHorizontal="24dp">

                <!-- Logo with circular background -->
                <FrameLayout
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_marginBottom="16dp">



                    <ImageView
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:layout_gravity="center"
                        android:src="@drawable/amrita_logo"
                        android:padding="6dp"/>
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome Back"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fill in your details to get started"
                    android:textColor="#8FAAC8"
                    android:textSize="14sp"
                    android:layout_marginTop="6dp"
                    android:fontFamily="sans-serif"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Form Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="#1A2D45"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Section Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PERSONAL INFO"
                    android:textColor="#4D9FFF"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"
                    android:fontFamily="sans-serif-medium"/>

                <!-- Name Field -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Full Name"
                    android:textColor="#8FAAC8"
                    android:textSize="12sp"
                    android:layout_marginBottom="6dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="18dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="#2E4A6A"
                    app:boxBackgroundColor="#0F2035"
                    app:hintTextColor="#8FAAC8">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Name"
                        android:inputType="textPersonName"
                        android:textColor="#e8dcdc"
                        android:textColorHint="#e8dcdc"
                        android:paddingHorizontal="16dp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Email Field -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email Address"
                    android:textColor="#8FAAC8"
                    android:textSize="12sp"
                    android:layout_marginBottom="6dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="18dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="#2E4A6A"
                    app:boxBackgroundColor="#0F2035"
                    app:hintTextColor="#8FAAC8"
                    app:startIconTint="#4D9FFF">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="example@email.com"
                        android:inputType="textEmailAddress"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#4A6A8A"
                        android:paddingHorizontal="16dp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Phone Field -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phone Number"
                    android:textColor="#8FAAC8"
                    android:textSize="12sp"
                    android:layout_marginBottom="6dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="#2E4A6A"
                    app:boxBackgroundColor="#0F2035"
                    app:hintTextColor="#8FAAC8"

                    app:startIconTint="#4D9FFF">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/phone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="+91 XXXXX XXXXX"
                        android:inputType="phone"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#4A6A8A"
                        android:paddingHorizontal="16dp"/>
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Gender Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="#1A2D45"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GENDER"
                    android:textColor="#4D9FFF"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <RadioGroup
                    android:id="@+id/gender"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Male Option -->


                        <RadioButton
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"

                            android:layout_margin="16sp"
                            android:text="  Male"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:buttonTint="#4D9FFF"/>



                        <RadioButton
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="  Female"
                            android:layout_margin="16sp"

                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:buttonTint="#FF6B9D"/>

                </RadioGroup>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Interests Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="#1A2D45"
            android:layout_marginBottom="28dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="INTERESTS"
                    android:textColor="#4D9FFF"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <!-- Cricket -->
                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/cricket"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="  🏏  Cricket"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:gravity="center_vertical"

                    android:layout_marginBottom="10dp"
                    android:paddingHorizontal="12dp"
                    app:buttonTint="#4D9FFF"/>

                <!-- Football -->
                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/football"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="  ⚽  Football"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:gravity="center_vertical"

                    android:layout_marginBottom="10dp"
                    android:paddingHorizontal="12dp"
                    app:buttonTint="#4D9FFF"/>


                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/badminton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="  🏸  Badminton"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:gravity="center_vertical"

                    android:paddingHorizontal="12dp"
                    app:buttonTint="#4D9FFF"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>


        <com.google.android.material.button.MaterialButton
            android:id="@+id/add_complint"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_gravity="right"
            android:text="Add Complaint"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.05"
            app:backgroundTint="#4D9FFF"
            app:cornerRadius="18dp"
            app:elevation="8dp"
            android:fontFamily="sans-serif-medium"/>

    </LinearLayout>

</ScrollView>